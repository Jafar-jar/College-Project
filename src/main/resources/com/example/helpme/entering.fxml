<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<Pane fx:id="enterPain" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.helpme.LoginScreen">
    <children>
        <Button layoutX="450.0" layoutY="250.0" mnemonicParsing="false" onAction="#entering" prefHeight="45.0" prefWidth="30.0" style="-fx-background-color: transparent; -fx-padding: 0;">
            <graphic>
                <ImageView fitHeight="81.0" fitWidth="175.0">
                    <image>
                        <Image url="@start.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
        <Button layoutX="450.0" layoutY="350.0" mnemonicParsing="false" onAction="#entering" prefHeight="45.0" prefWidth="30.0" style="-fx-background-color: transparent; -fx-padding: 0;">
            <graphic>
                <ImageView fitHeight="81.0" fitWidth="175.0">
                    <image>
                        <Image url="@setting.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
        <Button layoutX="420.0" layoutY="450.0" mnemonicParsing="false" onAction="#back" prefHeight="45.0" prefWidth="30.0" style="-fx-background-color: transparent; -fx-padding: 0;">
            <graphic>
                <ImageView fitHeight="81.0" fitWidth="230.0">
                    <image>
                        <Image url="@bBack.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
        <Button layoutX="450.0" layoutY="550.0" mnemonicParsing="false" onAction="#quitGame" prefHeight="45.0" prefWidth="30.0" style="-fx-background-color: transparent; -fx-padding: 0;">
            <graphic>
                <ImageView fitHeight="81.0" fitWidth="175.0">
                    <image>
                        <Image url="@quit.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
      <VBox fx:id="result" layoutY="400.0" prefHeight="200.0" prefWidth="370.0" />
      <Label fx:id="summery" layoutX="14.0" layoutY="350.0" prefHeight="30.0" prefWidth="1000.0" textFill="#00ff26" wrapText="true">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
    </children>
</Pane>
